# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_MICROSOFT_CLIENT_ID: Optional Microsoft Azure AD Client ID for Microsoft Graph Integration.
VITE_MICROSOFT_CLIENT_ID="YOUR_MICROSOFT_CLIENT_ID_GUID"


# VITE_MICROSOFT_TENANT_ID: Optional Microsoft Entra ID (Azure AD) Tenant ID.
# Use 'common' for multi-tenant (personal & work accounts), 'organizations' for work/school accounts only,
# or a specific Tenant ID (GUID) for a single-tenant application.
VITE_MICROSOFT_TENANT_ID="common"
